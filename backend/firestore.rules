rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for role checking
    function isAuthenticated() {
      return request.auth != null;
    }

    function isRole(role) {
      return isAuthenticated()
        && request.auth.token.role == role;
    }

    function isOneOfRoles(roles) {
      return isAuthenticated()
        && roles.hasAny([request.auth.token.role]);
    }

    function belongsToFacility(facilityId) {
      return isAuthenticated()
        && request.auth.token.facilityId == facilityId;
    }

    // medicineConsignments
    match /medicineConsignments/{consignmentId} {
      allow read: if isAuthenticated();
      allow create: if isOneOfRoles(['natpharm_admin', 'natpharm_officer']);
      allow update: if isOneOfRoles(['natpharm_admin', 'natpharm_officer', 'pharmacist', 'hospital_admin']);
      allow delete: if isOneOfRoles(['natpharm_admin']);
    }

    // facilityStock
    match /facilityStock/{stockId} {
      allow read: if isAuthenticated()
        && (isOneOfRoles(['natpharm_admin', 'natpharm_officer', 'ministry_viewer'])
            || belongsToFacility(stockId.split('_')[0]));
      allow write: if isAuthenticated()
        && (isOneOfRoles(['natpharm_admin'])
            || belongsToFacility(stockId.split('_')[0]));
    }

    // stockMovements (audit log - append only)
    match /stockMovements/{movementId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && (isOneOfRoles(['pharmacist', 'hospital_admin', 'natpharm_officer', 'natpharm_admin']));
      allow update: if isOneOfRoles(['natpharm_admin']);
      allow delete: if false;
    }

    // facilities
    match /facilities/{facilityId} {
      allow read: if isAuthenticated();
      allow write: if isOneOfRoles(['natpharm_admin']);
    }

    // suppliers
    match /suppliers/{supplierId} {
      allow read: if isAuthenticated();
      allow write: if isOneOfRoles(['natpharm_admin']);
    }

    // purchaseRequests (generated by reorder engine)
    match /purchaseRequests/{requestId} {
      allow read: if isAuthenticated()
        && (isOneOfRoles(['natpharm_admin', 'natpharm_officer', 'ministry_viewer'])
            || belongsToFacility(request.resource.data.facilityId));
      allow create: if isOneOfRoles(['natpharm_admin', 'natpharm_officer']);
      allow update: if isOneOfRoles(['natpharm_admin', 'natpharm_officer']);
      allow delete: if isOneOfRoles(['natpharm_admin']);
    }

    // notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated()
        && request.resource.data.targetRoles.hasAny([request.auth.token.role])
        && (request.resource.data.facilityId == null
            || belongsToFacility(request.resource.data.facilityId));
      allow write: if isOneOfRoles(['natpharm_admin', 'natpharm_officer']);
      allow delete: if isOneOfRoles(['natpharm_admin']);
    }

    // users (managed by Firebase Auth + custom claims)
    match /users/{userId} {
      allow read: if isAuthenticated()
        && (isOneOfRoles(['natpharm_admin', 'natpharm_officer', 'ministry_viewer'])
            || request.auth.uid == userId);
      allow write: if isAuthenticated()
        && (isOneOfRoles(['natpharm_admin'])
            || request.auth.uid == userId);
      allow delete: if isOneOfRoles(['natpharm_admin']);
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
