# HealthBridge MedTrack - Mobile Environment Configuration
# Pass these as --dart-define flags when building:
#
# Example:
#   flutter run --dart-define=FIREBASE_API_KEY=AIza... --dart-define=FIREBASE_APP_ID=1:123...
#
# For development with Firebase Emulator:
#   flutter run --dart-define=API_BASE_URL=http://localhost:5001/healthbridge-medtrack/us-central1

FIREBASE_API_KEY=your_api_key_here
FIREBASE_APP_ID=your_app_id_here
FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
FIREBASE_PROJECT_ID=healthbridge-medtrack
FIREBASE_STORAGE_BUCKET=healthbridge-medtrack.appspot.com
FIREBASE_AUTH_DOMAIN=healthbridge-medtrack.firebaseapp.com
FIREBASE_DATABASE_URL=https://healthbridge-medtrack.firebaseio.com
FIREBASE_IOS_BUNDLE_ID=com.healthbridge.medtrack
FIREBASE_ANDROID_CLIENT_ID=your_android_client_id
FIREBASE_IOS_CLIENT_ID=your_ios_client_id
API_BASE_URL=https://api.healthbridge.co.zw/v1
